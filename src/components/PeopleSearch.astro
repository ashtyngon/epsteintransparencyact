---
import { getCollection } from 'astro:content';
import { categoryColorClass, categoryLabelShort } from '../utils/categories';

const people = await getCollection('people');
const searchData = people
  .map((p) => ({
    id: p.id,
    name: p.data.name,
    aliases: (p.data.aliases || []).filter(Boolean),
    role: p.data.role,
    category: p.data.category,
    image: p.data.image || '',
  }))
  .sort((a, b) => a.name.localeCompare(b.name));
const total = people.length;
---

<div class="relative max-w-2xl" data-people-search>
  <div class="flex items-center gap-3 bg-white border border-white/20 focus-within:ring-2 focus-within:ring-accent px-4 py-3.5">
    <svg class="w-5 h-5 text-text-muted flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M11 18a7 7 0 100-14 7 7 0 000 14z" />
    </svg>
    <label for="people-search-input" class="sr-only">Search names in the Epstein files</label>
    <input
      id="people-search-input"
      type="search"
      autocomplete="off"
      spellcheck="false"
      placeholder="Search a name — is someone in the files?"
      class="w-full bg-transparent text-text text-base placeholder:text-text-muted focus:outline-none"
      aria-controls="people-search-results"
      aria-expanded="false"
      role="combobox"
    />
  </div>
  <div
    id="people-search-results"
    class="hidden absolute left-0 right-0 top-full mt-2 bg-white border border-border shadow-lg z-50 max-h-[60vh] overflow-y-auto text-left"
    role="listbox"
  >
  </div>
</div>

<script define:vars={{ searchData, total, colorMap: categoryColorClass, labelMap: categoryLabelShort }}>
  const root = document.querySelector('[data-people-search]');
  const input = document.getElementById('people-search-input');
  const panel = document.getElementById('people-search-results');

  if (root && input && panel) {
    const esc = (s) =>
      String(s).replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
    const initials = (name) => name.split(' ').map((n) => n[0]).join('').slice(0, 2).toUpperCase();

    function rowHtml(p) {
      const badge = colorMap[p.category] || 'bg-gray-600 text-white';
      const label = labelMap[p.category] || p.category;
      const avatar = p.image
        ? `<img src="${esc(p.image)}" alt="" class="w-9 h-9 rounded-full object-cover flex-shrink-0" loading="lazy" />`
        : `<span class="w-9 h-9 rounded-full bg-primary/10 flex items-center justify-center text-[11px] font-bold text-primary/50 flex-shrink-0">${esc(initials(p.name))}</span>`;
      return `<a href="/people/${p.id}/" class="flex items-center gap-3 px-4 py-2.5 hover:bg-surface-dark transition-colors no-underline border-b border-border last:border-b-0" role="option">
        ${avatar}
        <span class="min-w-0 flex-1">
          <span class="block text-sm font-semibold text-primary truncate">${esc(p.name)}</span>
          <span class="block text-xs text-text-muted truncate">${esc(p.role)}</span>
        </span>
        <span class="text-[9px] font-semibold uppercase tracking-wider px-1.5 py-0.5 flex-shrink-0 ${badge}">${esc(label)}</span>
      </a>`;
    }

    function run(raw) {
      const query = raw.trim().toLowerCase();
      if (query.length < 2) {
        panel.classList.add('hidden');
        input.setAttribute('aria-expanded', 'false');
        return;
      }
      const matches = searchData.filter(
        (p) => p.name.toLowerCase().includes(query) || p.aliases.some((a) => a.toLowerCase().includes(query)),
      );
      matches.sort((a, b) => {
        const as = a.name.toLowerCase().startsWith(query) ? 0 : 1;
        const bs = b.name.toLowerCase().startsWith(query) ? 0 : 1;
        return as - bs || a.name.localeCompare(b.name);
      });

      let html;
      if (matches.length === 0) {
        html = `<div class="px-4 py-5">
          <p class="text-sm text-text"><span class="font-semibold">No one named &ldquo;${esc(raw.trim())}&rdquo;</span> currently appears in our records of the Epstein files.</p>
          <p class="text-xs text-text-muted mt-1">The list is updated daily as new documents are released.</p>
          <div class="mt-3 flex flex-wrap gap-4 text-xs font-semibold">
            <a href="#directory" class="text-accent hover:text-primary" data-close-search>Browse all ${total} names &rarr;</a>
            <a href="/search/" class="text-accent hover:text-primary">Search news coverage &rarr;</a>
          </div>
        </div>`;
      } else {
        const shown = matches.slice(0, 8);
        html = shown.map(rowHtml).join('');
        if (matches.length > shown.length) {
          html += `<a href="#directory" class="block px-4 py-2.5 text-xs font-semibold text-accent hover:bg-surface-dark" data-close-search>See all ${matches.length} matches in the list &rarr;</a>`;
        }
      }
      panel.innerHTML = html;
      panel.classList.remove('hidden');
      input.setAttribute('aria-expanded', 'true');
    }

    input.addEventListener('input', () => run(input.value));
    input.addEventListener('focus', () => {
      if (input.value.trim().length >= 2) run(input.value);
    });
    document.addEventListener('click', (e) => {
      if (!root.contains(e.target)) {
        panel.classList.add('hidden');
        input.setAttribute('aria-expanded', 'false');
      }
      if (e.target.closest('[data-close-search]')) panel.classList.add('hidden');
    });
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        panel.classList.add('hidden');
        input.blur();
      }
      if (e.key === 'Enter') {
        const first = panel.querySelector('a[role="option"]');
        if (first) window.location.href = first.getAttribute('href');
      }
    });
  }
</script>
